{"schema":1,"name":"nmap-vnc","version":1,"kind_prefix":"nmap","default_port":5900,
 "description":"vnc service/version detection",
 "steps":[
  {"op":"connect_tcp","host":"$target.host","port":"$target.port","timeout_ms":5000,"out":"c"},
  {"op":"recv","conn":"c","until":"newline","max_bytes":32,"out":"banner"},
  {"op":"match","in":"banner","regex":"^RFB 00([0-9])\\.0*([0-9]+)",
   "captures":[{"name":"major","as":"int"},{"name":"minor","as":"int"}]},
  {"op":"if","cond":"exists","binding":"minor","then":[
    {"op":"emit","kind":"nmap.service","severity":"info","confidence":"confirmed",
     "title":"vnc RFB $major.$minor",
     "evidence":{"port":{"as":"int","value":"$target.port"},
       "service":"vnc","product":"VNC","version":"$major.$minor","banner":"$banner"}}]},
  {"op":"close","conn":"c"}]}
