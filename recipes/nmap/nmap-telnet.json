{"schema":1,"name":"nmap-telnet","version":1,"kind_prefix":"nmap","default_port":23,
 "description":"telnet presence detection (IAC negotiation / login banner)",
 "steps":[
  {"op":"connect_tcp","host":"$target.host","port":"$target.port","timeout_ms":5000,"out":"c"},
  {"op":"recv","conn":"c","until":"n_bytes","n_bytes":16,"max_bytes":16,"out":"resp"},
  {"op":"match","in":"resp","regex":"^(.)","captures":[{"name":"hit","as":"string"}]},
  {"op":"if","cond":"exists","binding":"hit","then":[
    {"op":"emit","kind":"nmap.service","severity":"info","confidence":"tentative",
     "title":"telnet (presence)",
     "evidence":{"port":{"as":"int","value":"$target.port"},
       "service":"telnet","product":"","version":"","banner":"telnet reply"}}]},
  {"op":"close","conn":"c"}]}
