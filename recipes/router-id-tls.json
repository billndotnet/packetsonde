{
 "schema": 2,
 "name": "router-id-tls",
 "version": 1,
 "kind_prefix": "router",
 "default_port": 443,
 "description": "COTS router/gateway identification via HTTPS admin interface",
 "budgets": {
  "max_steps": 64
 },
 "steps": [
  {
   "op": "connect_tcp",
   "host": "$target.host",
   "port": "$target.port",
   "timeout_ms": 5000,
   "out": "c"
  },
  {
   "op": "tls_upgrade",
   "conn": "c",
   "sni": "$target.host",
   "alpn": [
    "http/1.1"
   ],
   "timeout_ms": 5000
  },
  {
   "op": "send",
   "conn": "c",
   "bytes": "GET / HTTP/1.0\r\nHost: $target.host\r\nUser-Agent: Mozilla/5.0\r\nConnection: close\r\n\r\n"
  },
  {
   "op": "recv",
   "conn": "c",
   "until": "n_bytes",
   "n_bytes": 8192,
   "max_bytes": 8192,
   "out": "resp"
  },
  {
   "op": "if",
   "cond": "matches",
   "binding": "resp",
   "literal": "NETGEAR",
   "then": [
    {
     "op": "emit",
     "kind": "router.identified",
     "severity": "info",
     "confidence": "firm",
     "title": "Gateway: NETGEAR",
     "evidence": {
      "vendor": "NETGEAR",
      "signal": "http-body",
      "transport": "https",
      "port": {
       "as": "int",
       "value": "$target.port"
      }
     }
    }
   ]
  },
  {
   "op": "if",
   "cond": "matches",
   "binding": "resp",
   "literal": "(ASUS|asuswrt)",
