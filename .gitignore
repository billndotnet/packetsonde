# Local development scaffolding — design specs + implementation plans guide
# development but are kept local, not pushed. Durable reference docs
# (central-protocol-v1.md, whitepaper.md, viz-notes.md) and docs/guides/
# stay tracked.
docs/specs/20*-*.md
docs/plans/
docs/reviews/

# Build trees (out-of-tree)
build-rel/
build-test/

# generated by debian/rules at build time
debian/packetsonded.service

# dpkg-buildpackage / debhelper byproducts (removed by `debian/rules clean`,
# ignored here so a partial build never leaks them into a commit)
debian/.debhelper/
debian/debhelper-build-stamp
debian/files
debian/*.debhelper
debian/*.debhelper.log
debian/*.substvars
debian/packetsonde/
obj-*/
