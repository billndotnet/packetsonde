#!/bin/sh
# packetsonde-bridge-setup — generate network bridge config for inline tap deployment
#
# Creates a Layer 2 bridge between two interfaces for passive traffic observation.
# Generates netplan, systemd-networkd, or FreeBSD rc.conf configuration.

set -e

IFACE1=""
IFACE2=""
BRIDGE_NAME="br0"
DHCP=""
APPLY=""
OUTPUT_DIR=""

usage() {
    cat <<'USAGE'
Usage: packetsonde-bridge-setup --iface1 eth0 --iface2 eth1 [OPTIONS]

Required:
  --iface1 NAME      First bridge member interface
  --iface2 NAME      Second bridge member interface

Options:
  --bridge-name NAME  Bridge interface name (default: br0)
  --dhcp             Enable DHCP on bridge for management connectivity
  --apply            Write config files and apply immediately
  --output DIR       Output directory (default: auto-detected)
  -h, --help         Show this help

Without --apply, prints the generated config to stdout for review.

After creating the bridge, set the capture interface in the agent config:
  Edit /etc/packetsonde/packetsonde.conf:
    [agent]
    interface = br0
USAGE
    exit 0
}

while [ $# -gt 0 ]; do
    case "$1" in
        --iface1)       IFACE1="$2"; shift 2 ;;
        --iface1=*)     IFACE1="${1#*=}"; shift ;;
        --iface2)       IFACE2="$2"; shift 2 ;;
        --iface2=*)     IFACE2="${1#*=}"; shift ;;
        --bridge-name)  BRIDGE_NAME="$2"; shift 2 ;;
        --bridge-name=*)BRIDGE_NAME="${1#*=}"; shift ;;
        --dhcp)         DHCP="yes"; shift ;;
        --apply)        APPLY="yes"; shift ;;
        --output)       OUTPUT_DIR="$2"; shift 2 ;;
        --output=*)     OUTPUT_DIR="${1#*=}"; shift ;;
        -h|--help)      usage ;;
        *)              echo "Unknown option: $1"; exit 1 ;;
    esac
done

if [ -z "$IFACE1" ] || [ -z "$IFACE2" ]; then
    echo "Error: --iface1 and --iface2 are required" >&2
    echo "Run '$0 --help' for usage" >&2
    exit 1
fi

if [ "$IFACE1" = "$IFACE2" ]; then
    echo "Error: iface1 and iface2 must be different interfaces" >&2
    exit 1
fi

# ── Platform detection ──

PLATFORM=$(uname -s)

check_iface_exists() {
    local iface="$1"
    case "$PLATFORM" in
        Linux)
            if [ ! -d "/sys/class/net/$iface" ]; then
                echo "Error: interface $iface does not exist" >&2
                exit 1
            fi
            ;;
        FreeBSD)
            if ! ifconfig "$iface" >/dev/null 2>&1; then
                echo "Error: interface $iface does not exist" >&2
                exit 1
            fi
            ;;
        *)
            echo "Warning: cannot verify interface $iface on $PLATFORM" >&2
            ;;
    esac
}

check_not_default_route() {
    local iface="$1"
    case "$PLATFORM" in
        Linux)
            local def_iface
            def_iface=$(ip route show default 2>/dev/null | awk '{print $5; exit}')
            if [ "$iface" = "$def_iface" ]; then
                echo "Error: $iface is the default route interface — bridging it would lose connectivity" >&2
                echo "Use a different interface, or ensure you have alternate management access." >&2
                exit 1
            fi
            ;;
        FreeBSD)
            local def_iface
            def_iface=$(route -n get default 2>/dev/null | awk '/interface:/{print $2}')
            if [ "$iface" = "$def_iface" ]; then
                echo "Error: $iface is the default route interface — bridging it would lose connectivity" >&2
                exit 1
            fi
            ;;
    esac
}

check_iface_exists "$IFACE1"
check_iface_exists "$IFACE2"
check_not_default_route "$IFACE1"
check_not_default_route "$IFACE2"

# ── Config system detection (Linux) ──

detect_config_system() {
    if command -v netplan >/dev/null 2>&1; then
        echo "netplan"
    elif [ -d /etc/systemd/network ]; then
        echo "networkd"
    else
        echo "unknown"
    fi
}

# ── Generators ──

generate_netplan() {
    local dhcp_line
    if [ -n "$DHCP" ]; then
        dhcp_line="      dhcp4: true"
    else
        dhcp_line="      dhcp4: false"
    fi

    cat <<NETPLAN
# Generated by packetsonde-bridge-setup
# Bridge: $BRIDGE_NAME with members $IFACE1, $IFACE2
network:
  version: 2
  ethernets:
    $IFACE1:
      dhcp4: false
    $IFACE2:
      dhcp4: false
  bridges:
    $BRIDGE_NAME:
      interfaces: [$IFACE1, $IFACE2]
      parameters:
        stp: false
        forward-delay: 0
$dhcp_line
NETPLAN
}

generate_networkd() {
    echo "# ── $BRIDGE_NAME.netdev ──"
    cat <<NETDEV
[NetDev]
Name=$BRIDGE_NAME
Kind=bridge

[Bridge]
STP=false
ForwardDelaySec=0
NETDEV

    echo ""
    echo "# ── $IFACE1.network ──"
    cat <<NET1
[Match]
Name=$IFACE1

[Network]
Bridge=$BRIDGE_NAME
NET1

    echo ""
    echo "# ── $IFACE2.network ──"
    cat <<NET2
[Match]
Name=$IFACE2

[Network]
Bridge=$BRIDGE_NAME
NET2

    echo ""
    echo "# ── $BRIDGE_NAME.network ──"
    if [ -n "$DHCP" ]; then
        cat <<BRNET
[Match]
Name=$BRIDGE_NAME

[Network]
DHCP=yes
BRNET
    else
        cat <<BRNET
[Match]
Name=$BRIDGE_NAME

[Network]
# No IP — bridge is L2 only
# Uncomment to enable DHCP:
# DHCP=yes
BRNET
    fi
}

generate_freebsd() {
    cat <<FBSD
# Add to /etc/rc.conf for packetsonde bridge
cloned_interfaces="\${cloned_interfaces} bridge0"
ifconfig_bridge0="addm $IFACE1 addm $IFACE2 up"
FBSD
    if [ -n "$DHCP" ]; then
        echo "ifconfig_bridge0_alias0=\"DHCP\""
    fi
}

# ── Output ──

case "$PLATFORM" in
    Linux)
        CONFIG_SYS=$(detect_config_system)
        case "$CONFIG_SYS" in
            netplan)
                CONFIG=$(generate_netplan)
                DEFAULT_OUTPUT="/etc/netplan"
                CONFIG_FILE="60-packetsonde-bridge.yaml"
                APPLY_CMD="netplan apply"
                ;;
            networkd)
                CONFIG=$(generate_networkd)
                DEFAULT_OUTPUT="/etc/systemd/network"
                CONFIG_FILE=""  # multiple files
                APPLY_CMD="networkctl reload"
                ;;
            *)
                echo "Warning: could not detect netplan or systemd-networkd" >&2
                echo "Generating netplan config (install netplan or adjust manually)" >&2
                CONFIG=$(generate_netplan)
                DEFAULT_OUTPUT="/etc/netplan"
                CONFIG_FILE="60-packetsonde-bridge.yaml"
                APPLY_CMD="netplan apply"
                ;;
        esac
        ;;
    FreeBSD)
        CONFIG=$(generate_freebsd)
        DEFAULT_OUTPUT="/etc"
        CONFIG_FILE="rc.conf"
        APPLY_CMD="service netif restart && service routing restart"
        ;;
    *)
        echo "Warning: unsupported platform $PLATFORM — generating netplan config for reference" >&2
        CONFIG=$(generate_netplan)
        DEFAULT_OUTPUT="/etc/netplan"
        CONFIG_FILE="60-packetsonde-bridge.yaml"
        APPLY_CMD="netplan apply"
        ;;
esac

[ -z "$OUTPUT_DIR" ] && OUTPUT_DIR="$DEFAULT_OUTPUT"

if [ -z "$APPLY" ]; then
    # Print to stdout
    echo "$CONFIG"
    echo ""
    echo "# To apply: re-run with --apply"
    echo "# Then set in /etc/packetsonde/packetsonde.conf:"
    echo "#   [agent]"
    echo "#   interface = $BRIDGE_NAME"
else
    # Write and apply
    case "$PLATFORM" in
        Linux)
            case "$CONFIG_SYS" in
                netplan)
                    echo "$CONFIG" > "$OUTPUT_DIR/$CONFIG_FILE"
                    echo "Wrote $OUTPUT_DIR/$CONFIG_FILE"
                    ;;
                networkd)
                    generate_networkd | awk -v dir="$OUTPUT_DIR" '
                        /^# ── .*.netdev/ { fname=dir"/60-"BRIDGE".netdev"; next }
                        /^# ── .*IFACE1/ { fname=dir"/61-"BRIDGE"-"IFACE1".network"; next }
                        /^# ── .*IFACE2/ { fname=dir"/61-"BRIDGE"-"IFACE2".network"; next }
                        /^# ── .*BRIDGE.network/ { fname=dir"/62-"BRIDGE".network"; next }
                        fname { print > fname }
                    ' BRIDGE="$BRIDGE_NAME" IFACE1="$IFACE1" IFACE2="$IFACE2"
                    echo "Wrote networkd configs to $OUTPUT_DIR/"
                    ;;
            esac
            ;;
        FreeBSD)
            # Append to rc.conf
            echo "" >> /etc/rc.conf
            echo "$CONFIG" >> /etc/rc.conf
            echo "Appended bridge config to /etc/rc.conf"
            ;;
    esac

    echo "Applying..."
    eval $APPLY_CMD
    echo ""
    echo "Bridge $BRIDGE_NAME created with members $IFACE1, $IFACE2."
    echo ""
    echo "Next: set capture interface in /etc/packetsonde/packetsonde.conf:"
    echo "  [agent]"
    echo "  interface = $BRIDGE_NAME"
fi
