{#- Rendered packetsonded config. Central settings come from pillar; agent_id
    is the minion id. config_to_env strips the wrapping quotes at load. -#}
[keys]
dir = "/etc/packetsonded/keys"

[central]
url             = "{{ salt['pillar.get']('packetsonde:central_url', '') }}"
agent_id        = "{{ grains['id'] }}"
deployment_mode = "{{ salt['pillar.get']('packetsonde:deployment_mode', 'host') }}"
verify          = "{{ salt['pillar.get']('packetsonde:verify', '1') }}"
ca_cert         = "{{ salt['pillar.get']('packetsonde:ca_cert', '') }}"
checkin_seconds = "{{ salt['pillar.get']('packetsonde:checkin_seconds', '60') }}"

[agent_listen]
mode = "{{ salt['pillar.get']('packetsonde:agent_listen_mode', 'persistent') }}"
addr = "{{ salt['pillar.get']('packetsonde:agent_listen_addr', '0.0.0.0') }}"
port = "{{ salt['pillar.get']('packetsonde:agent_listen_port', '8442') }}"
key  = "agent"
{% if salt['pillar.get']('packetsonde:discovery_enabled', '0') == '1' %}

[discovery]
enabled     = "1"
listen_ip   = "{{ salt['pillar.get']('packetsonde:discovery_listen_ip', grains['id']) }}"
listen_port = "{{ salt['pillar.get']('packetsonde:discovery_listen_port', '8442') }}"
{% endif %}

# Process/file/socket behavioral collection (Linux). Off by default — set
# packetsonde:detect_enabled "1" in pillar to turn it on. The `sink` is what
# `packetsonde inspect` and `packetsonde watch` read; the agent only writes it
# when enabled and the directory exists (the state creates /var/lib/packetsonde).
[detect]
enabled            = "{{ salt['pillar.get']('packetsonde:detect_enabled', '0') }}"
sink               = "{{ salt['pillar.get']('packetsonde:detect_sink', '/var/lib/packetsonde/activity.jsonl') }}"
watch_paths        = "{{ salt['pillar.get']('packetsonde:detect_watch_paths', '/etc,/home') }}"
max_events_ps      = "{{ salt['pillar.get']('packetsonde:detect_max_events_ps', '2000') }}"
policy_mode        = "{{ salt['pillar.get']('packetsonde:detect_policy_mode', 'off') }}"
baseline_mode      = "{{ salt['pillar.get']('packetsonde:detect_baseline_mode', 'off') }}"
baseline_state_dir = "{{ salt['pillar.get']('packetsonde:detect_baseline_state_dir', '/var/lib/packetsonde/baseline') }}"
provenance_enabled         = "{{ salt['pillar.get']('packetsonde:detect_provenance_enabled', '0') }}"
provenance_transient_paths = "{{ salt['pillar.get']('packetsonde:detect_provenance_transient_paths', '/tmp,/var/tmp,/dev/shm,/run,/home') }}"
provenance_sensitive_paths = "{{ salt['pillar.get']('packetsonde:detect_provenance_sensitive_paths', '/etc/cron.d,/etc/cron.daily,/etc/systemd/system,/etc/ld.so.preload,/usr/local/sbin,/lib/modules,/etc/rc.local') }}"
