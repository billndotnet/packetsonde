<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd plist for packetsonded on macOS.

  Install:
    sudo cp net.billn.packetsonded.plist /Library/LaunchDaemons/
    sudo chown root:wheel /Library/LaunchDaemons/net.billn.packetsonded.plist
    sudo launchctl bootstrap system /Library/LaunchDaemons/net.billn.packetsonded.plist

  Uninstall:
    sudo launchctl bootout system /Library/LaunchDaemons/net.billn.packetsonded.plist
    sudo rm /Library/LaunchDaemons/net.billn.packetsonded.plist

  pcap on macOS requires root or membership in the access_bpf group. The
  daemon runs as root by default; lock that down with the Unix user model
  if your deployment allows it.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>net.billn.packetsonded</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/sbin/packetsonded</string>
        <string>-c</string>
        <string>/usr/local/etc/packetsonded/packetsonded.toml</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>/usr/local/var/log/packetsonded/stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/usr/local/var/log/packetsonded/stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PS_KEY_DIR</key>
        <string>/usr/local/etc/packetsonded/keys</string>
    </dict>

    <key>SoftResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>4096</integer>
    </dict>
</dict>
</plist>
